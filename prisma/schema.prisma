generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                    @id
  name                String
  email               String?                   @unique
  passwordHash        String?
  image               String?
  role                Role                      @default(PUBLIC_VIEWER)
  status              UserStatus                @default(ACTIVE)
  regionId            String                    @default("bela")
  phone               String?                   @unique
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  blockedAt           DateTime?
  blockedReason       String?
  requestedTournaments Tournament[]             @relation("TournamentRequester")
  approvedTournaments Tournament[]              @relation("TournamentApprover")
  managedTournaments  Tournament[]              @relation("TournamentManager")
  ownedTeams          Team[]                    @relation("TeamOwner")
  teamApplications    TeamTournamentApplication[] @relation("TeamApplicationRequester")
  directMatchRequests DirectMatchRequest[]
  ballEvents          BallEvent[]               @relation("BallCreatedBy")
  matchAssignments    MatchOfficialAssignment[]
  correctionRequests  ScoreCorrection[]         @relation("CorrectionRequestedBy")
  correctionApprovals ScoreCorrection[]         @relation("CorrectionApprovedBy")
  auditLogs           AuditLog[]
}

model Tournament {
  id               String            @id
  name             String
  regionId         String
  city             String?
  venue            String?
  format           String?
  overs            Int?
  ballType         String?
  tournamentType   String?
  organizerName    String?
  organizerPhone   String?
  sponsorName      String?
  totalTeams       Int?
  fixtureType      TournamentFixtureType? @default(ROUND_ROBIN)
  pointsWin        Int               @default(2)
  pointsLoss       Int               @default(0)
  pointsDraw       Int               @default(1)
  pointsTie        Int               @default(1)
  startDate        DateTime?
  endDate          DateTime?
  ruleSummary      String?
  adminUserId      String?
  status           TournamentStatus  @default(PENDING)
  requestedBy      String
  approvedBy       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  requester        User              @relation("TournamentRequester", fields: [requestedBy], references: [id])
  approver         User?             @relation("TournamentApprover", fields: [approvedBy], references: [id])
  admin            User?             @relation("TournamentManager", fields: [adminUserId], references: [id])
  teams            Team[]
  teamApplications TeamTournamentApplication[]
  matches          Match[]
  pointsTableRows  PointsTableRow[]
}

model TournamentRegistrationRequest {
  id              String                             @id
  name            String
  regionId        String
  city            String
  venue           String
  format          String
  overs           Int
  ballType        String
  tournamentType  String
  organizerName   String
  organizerPhone  String
  sponsorName     String?
  totalTeams      Int
  startDate       DateTime
  endDate         DateTime
  ruleSummary     String
  adminName       String
  adminEmail      String
  adminPhone      String
  adminPasswordHash String
  status          TournamentRegistrationRequestStatus @default(PENDING)
  rejectionReason String?
  submittedAt     DateTime                           @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
}

model Team {
  id                 String                    @id
  name               String
  sponsorName        String?
  city               String?
  logoUrl            String?
  captainName        String?
  contactPhone       String?
  ownerUserId        String?
  tournamentId       String?
  owner              User?                     @relation("TeamOwner", fields: [ownerUserId], references: [id])
  tournament         Tournament?               @relation(fields: [tournamentId], references: [id])
  homeMatchesA       Match[]                   @relation("TeamA")
  homeMatchesB       Match[]                   @relation("TeamB")
  battingInnings     MatchInnings[]            @relation("BattingTeamInnings")
  bowlingInnings     MatchInnings[]            @relation("BowlingTeamInnings")
  squadEntries       SquadEntry[]
  teamApplications   TeamTournamentApplication[]
  directRequestsSent DirectMatchRequest[]      @relation("DirectRequesterTeam")
  directRequestsReceived DirectMatchRequest[]  @relation("DirectOpponentTeam")
  pointsTableRows    PointsTableRow[]
}

model Player {
  id                 String              @id
  bcaId              String              @unique
  fullName           String
  verificationStatus VerificationStatus  @default(VERIFIED)
  squadEntries       SquadEntry[]
  battingEvents      BallEvent[]         @relation("BallStriker")
  nonStrikerEvents   BallEvent[]         @relation("BallNonStriker")
  bowlingEvents      BallEvent[]         @relation("BallBowler")
  dismissedInEvents  BallEvent[]         @relation("BallDismissedPlayer")
  promotedInEvents   BallEvent[]         @relation("BallNewBatter")
  fanVotes           FanVote[]
}

model SquadEntry {
  id           String   @id
  teamId       String
  playerId     String
  tournamentId String
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id])
  player       Player   @relation(fields: [playerId], references: [id])
  @@unique([playerId, tournamentId])
}

model Match {
  id               String            @id
  tournamentId     String?
  teamAId          String
  teamBId          String
  mode             MatchMode         @default(TOURNAMENT)
  state            MatchState        @default(SCHEDULED)
  venue            String?
  startAt          DateTime
  scheduledOvers   Int?
  ballsPerOver     Int               @default(6)
  powerplayOvers   Int?
  maxOversPerBowler Int?
  allowSuperOver   Boolean           @default(false)
  squadLockAt      DateTime
  tossWinnerTeamId String?
  electedTo        ElectChoice?
  winnerTeamId     String?
  winType          MatchWinType?
  winMarginRuns    Int?
  winMarginWickets Int?
  targetRuns       Int?
  currentInnings   Int               @default(1)
  updatedAt        DateTime          @updatedAt
  tournament       Tournament?       @relation(fields: [tournamentId], references: [id])
  teamA            Team              @relation("TeamA", fields: [teamAId], references: [id])
  teamB            Team              @relation("TeamB", fields: [teamBId], references: [id])
  officialAssignments MatchOfficialAssignment[]
  innings          MatchInnings[]
  ballEvents       BallEvent[]
  corrections      ScoreCorrection[]
  fanVotes         FanVote[]
}

model TeamTournamentApplication {
  id              String                @id
  teamId          String
  tournamentId    String
  requestedBy     String
  status          TeamApplicationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime              @default(now())
  reviewedBy      String?
  team            Team                  @relation(fields: [teamId], references: [id])
  tournament      Tournament            @relation(fields: [tournamentId], references: [id])
  requester       User                  @relation("TeamApplicationRequester", fields: [requestedBy], references: [id])
  @@unique([teamId, tournamentId])
}

model DirectMatchRequest {
  id              String                   @id
  requesterTeamId String
  opponentTeamId  String
  requestedBy     String
  format          String
  venue           String
  startAt         DateTime
  status          DirectMatchRequestStatus @default(PENDING)
  createdAt       DateTime                 @default(now())
  requesterTeam   Team                     @relation("DirectRequesterTeam", fields: [requesterTeamId], references: [id])
  opponentTeam    Team                     @relation("DirectOpponentTeam", fields: [opponentTeamId], references: [id])
  requester       User                     @relation(fields: [requestedBy], references: [id])
}

model BallEvent {
  id             String   @id
  matchId        String
  inningsId      String?
  over           Int
  ball           Int
  legalBallNumber Int?
  strikerId      String
  nonStrikerId   String?
  bowlerId       String
  runs           Int
  runsBat        Int      @default(0)
  extras         Int      @default(0)
  isWicket       Boolean
  extraType      ExtraType?
  wicketType     WicketType?
  outPlayerId    String?
  newBatterId    String?
  wagonZone      String?
  commentaryText String?
  isUndo         Boolean  @default(false)
  undoOfEventId  String?
  createdBy      String
  createdAt      DateTime @default(now())
  match          Match    @relation(fields: [matchId], references: [id])
  innings        MatchInnings? @relation(fields: [inningsId], references: [id])
  striker        Player   @relation("BallStriker", fields: [strikerId], references: [id])
  nonStriker     Player?  @relation("BallNonStriker", fields: [nonStrikerId], references: [id])
  bowler         Player   @relation("BallBowler", fields: [bowlerId], references: [id])
  dismissedPlayer Player? @relation("BallDismissedPlayer", fields: [outPlayerId], references: [id])
  newBatter      Player?  @relation("BallNewBatter", fields: [newBatterId], references: [id])
  creator        User     @relation("BallCreatedBy", fields: [createdBy], references: [id])
}

model ScoreCorrection {
  id           String   @id
  matchId      String
  targetEventId String
  reason       String
  requestedBy  String
  status       ScoreCorrectionStatus @default(REQUESTED)
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id])
  requester    User     @relation("CorrectionRequestedBy", fields: [requestedBy], references: [id])
  approver     User?    @relation("CorrectionApprovedBy", fields: [approvedBy], references: [id])
}

model MatchOfficialAssignment {
  id             String              @id
  matchId         String
  userId          String
  assignmentRole  MatchAssignmentRole
  assignedAt      DateTime            @default(now())
  assignedBy      String?
  match           Match               @relation(fields: [matchId], references: [id])
  user            User                @relation(fields: [userId], references: [id])

  @@unique([matchId, userId, assignmentRole])
}

model MatchInnings {
  id            String     @id
  matchId        String
  inningsNumber Int
  battingTeamId  String
  bowlingTeamId  String
  runs          Int        @default(0)
  wickets       Int        @default(0)
  balls         Int        @default(0)
  extras        Int        @default(0)
  byes          Int        @default(0)
  legByes       Int        @default(0)
  wides         Int        @default(0)
  noBalls       Int        @default(0)
  target        Int?
  startedAt     DateTime   @default(now())
  endedAt       DateTime?
  isCompleted   Boolean    @default(false)
  match         Match      @relation(fields: [matchId], references: [id])
  battingTeam   Team       @relation("BattingTeamInnings", fields: [battingTeamId], references: [id])
  bowlingTeam   Team       @relation("BowlingTeamInnings", fields: [bowlingTeamId], references: [id])
  ballEvents    BallEvent[]

  @@unique([matchId, inningsNumber])
}

model PointsTableRow {
  id               String      @id
  tournamentId     String
  teamId           String
  played           Int         @default(0)
  won              Int         @default(0)
  lost             Int         @default(0)
  drawn            Int         @default(0)
  tied             Int         @default(0)
  noResult         Int         @default(0)
  points           Int         @default(0)
  runsFor          Int         @default(0)
  oversFacedBalls  Int         @default(0)
  runsAgainst      Int         @default(0)
  oversBowledBalls Int         @default(0)
  netRunRate       Float       @default(0)
  position         Int?
  updatedAt        DateTime    @updatedAt
  tournament       Tournament  @relation(fields: [tournamentId], references: [id])
  team             Team        @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}

model LeaderboardSnapshot {
  id          String             @id
  scope       String
  generatedAt DateTime
  entries     LeaderboardEntry[]
}

model LeaderboardEntry {
  id          String              @id
  snapshotId  String
  subjectId   String
  label       String
  value       Int
  metric      LeaderboardMetric
  snapshot    LeaderboardSnapshot @relation(fields: [snapshotId], references: [id])
}

model FanVote {
  id         String   @id
  matchId     String
  playerId    String
  voterHash   String
  createdAt   DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id])
  player      Player   @relation(fields: [playerId], references: [id])
  @@unique([matchId, voterHash])
}

model NewsPost {
  id          String   @id
  title       String
  body        String
  publishedAt DateTime
}

model AuditLog {
  id         String   @id
  action     String
  actorId    String
  entityId   String
  metaJson   String?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])
}

enum Role {
  SUPER_ADMIN
  TOURNAMENT_ADMIN
  TEAM_ADMIN
  MATCH_SCORER
  PUBLIC_VIEWER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum TournamentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TournamentFixtureType {
  ROUND_ROBIN
  KNOCKOUT
  GROUP_STAGE
  HYBRID
}

enum VerificationStatus {
  VERIFIED
  FLAGGED
}

enum MatchState {
  SCHEDULED
  LIVE
  INNINGS_BREAK
  COMPLETED
  ABANDONED
  CANCELLED
}

enum ElectChoice {
  BAT
  BOWL
}

enum MatchMode {
  TOURNAMENT
  DIRECT
  FRIENDLY
}

enum MatchAssignmentRole {
  SCORER
  TOURNAMENT_ADMIN
  UMPIRE
}

enum MatchWinType {
  RUNS
  WICKETS
  TIE
  NO_RESULT
}

enum ExtraType {
  WD
  NB
  LB
  B
}

enum WicketType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
  OBSTRUCTING_FIELD
  TIMED_OUT
  RETIRED_OUT
  HANDLED_BALL
}

enum LeaderboardMetric {
  RUNS
  WICKETS
  POINTS
}

enum TeamApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DirectMatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ScoreCorrectionStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum TournamentRegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
